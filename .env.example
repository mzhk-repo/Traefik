COMPOSE_PROJECT_NAME=traefik

TRAEFIK_VERSION=v3.6.8
TRAEFIK_BIND_IP=
TRAEFIK_ENTRYPOINT_PORT=
DSPACENET_SUBNET=
VOL_LOGS_PATH=

TRAEFIK_DASHBOARD_HOST=traefik.example.com
TRAEFIK_DASHBOARD_ALLOWLIST=

SECURITY_FRAME_OPTIONS=SAMEORIGIN
CSP_REPORT_ONLY_POLICY=default-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; script-src 'self' https://analytics.example.com; connect-src 'self' https://analytics.example.com
